#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int numeroConta;
    char nome[50];
    float saldo;
    int ativo;
} Cliente;

void cadastrar(FILE *arquivo) {
    Cliente c;
    long pos;

    printf("Posicao do registro: ");
    scanf("%ld", &pos);

    printf("Numero da conta: ");
    scanf("%d", &c.numeroConta);

    printf("Nome: ");
    scanf(" %49[^\n]", c.nome);

    printf("Saldo: ");
    scanf("%f", &c.saldo);

    c.ativo = 1;

    fseek(arquivo, pos * sizeof(Cliente), SEEK_SET);
    fwrite(&c, sizeof(Cliente), 1, arquivo);
    fflush(arquivo);
}

void consultar(FILE *arquivo) {
    Cliente c;
    int conta;
    long pos = 0;

    printf("Numero da conta: ");
    scanf("%d", &conta);

    rewind(arquivo);

    while (fread(&c, sizeof(Cliente), 1, arquivo) == 1) {
        if (c.ativo && c.numeroConta == conta) {
            printf("\nConta: %d\n", c.numeroConta);
            printf("Nome: %s\n", c.nome);
            printf("Saldo: %.2f\n", c.saldo);
            return;
        }
        pos++;
    }

    printf("Cliente nao encontrado.\n");
}

void atualizarSaldo(FILE *arquivo) {
    Cliente c;
    int conta;
    float novoSaldo;
    long pos = 0;

    printf("Numero da conta: ");
    scanf("%d", &conta);

    rewind(arquivo);

    while (fread(&c, sizeof(Cliente), 1, arquivo) == 1) {
        if (c.ativo && c.numeroConta == conta) {
            printf("Novo saldo: ");
            scanf("%f", &novoSaldo);

            c.saldo = novoSaldo;

            fseek(arquivo, pos * sizeof(Cliente), SEEK_SET);
            fwrite(&c, sizeof(Cliente), 1, arquivo);
            fflush(arquivo);

            printf("Saldo atualizado.\n");
            return;
        }
        pos++;
    }

    printf("Cliente nao encontrado.\n");
}

void encerrarConta(FILE *arquivo) {
    Cliente c;
    int conta;
    long pos = 0;

    printf("Numero da conta: ");
    scanf("%d", &conta);

    rewind(arquivo);

    while (fread(&c, sizeof(Cliente), 1, arquivo) == 1) {
        if (c.ativo && c.numeroConta == conta) {
            c.ativo = 0;

            fseek(arquivo, pos * sizeof(Cliente), SEEK_SET);
            fwrite(&c, sizeof(Cliente), 1, arquivo);
            fflush(arquivo);

            printf("Conta encerrada.\n");
            return;
        }
        pos++;
    }

    printf("Cliente nao encontrado.\n");
}

void listar(FILE *arquivo) {
    Cliente c;

    while (fread(&c, sizeof(Cliente), 1, arquivo) == 1) {
        if (c.ativo) {
            printf("\nConta: %d\n", c.numeroConta);
            printf("Nome: %s\n", c.nome);
            printf("Saldo: %.2f\n", c.saldo);
        }
    }
}

int main() {
    FILE *arquivo;
    int opcao;

    arquivo = fopen("clientes.dat", "r+b");

    if (arquivo == NULL) {
        arquivo = fopen("clientes.dat", "w+b");
    }

    do {
        printf("\n1. Cadastrar novo cliente\n");
        printf("2. Consultar cliente\n");
        printf("3. Atualizar saldo\n");
        printf("4. Encerrar conta\n");
        printf("5. Listar clientes\n");
        printf("6. Rewind\n");
        printf("7. Encerrar\n");
        printf("Opcao: ");
        scanf("%d", &opcao);

        switch (opcao) {
            case 1:
                cadastrar(arquivo);
                break;

            case 2:
                consultar(arquivo);
                break;

            case 3:
                atualizarSaldo(arquivo);
                break;

            case 4:
                encerrarConta(arquivo);
                break;

            case 5:
                listar(arquivo);
                break;

            case 6:
                rewind(arquivo);
                printf("Leitura reposicionada para o inicio do arquivo.\n");
                break;

            case 7:
                break;

            default:
                printf("Opcao invalida.\n");
        }

    } while (opcao != 7);

    fclose(arquivo);

    return 0;
}